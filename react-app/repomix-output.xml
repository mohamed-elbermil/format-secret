/* ============================================
   VARIABLES CSS
   ============================================ */
:root {
  --color-primary: #000000;
  --color-secondary: #666666;
  --color-accent: #0066ff;
  --color-background: #ffffff;
  --color-surface: #f8f9fa;
  --color-border: #e5e7eb;
  --color-success: #10b981;
  --text-xs: 0.75rem;
  --text-sm: 0.875rem;
  --text-base: 1rem;
  --text-lg: 1.125rem;
  --text-xl: 1.25rem;
  --text-2xl: 1.5rem;
  --text-3xl: 1.875rem;
  --text-4xl: 2.25rem;
  --text-5xl: 3rem;
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 1.5rem;
  --spacing-lg: 2rem;
  --spacing-xl: 3rem;
  --spacing-2xl: 4rem;
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow-md:
    0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  --shadow-lg:
    0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

/* ============================================
     HERO
     ============================================ */
.formations-hero {
  padding: calc(var(--spacing-2xl) + 80px) 0 var(--spacing-2xl);
  text-align: center;
  background: var(--color-primary);
}

.hero-content h1 {
  font-size: var(--text-5xl);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: var(--spacing-md);
  letter-spacing: -0.02em;
  color: #fff;
}

.hero-subtitle {
  font-size: var(--text-xl);
  color: #fff;
  font-weight: 400;
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ============================================
     SECTION HEADERS
     ============================================ */
.section-header {
  text-align: center;
  margin-bottom: var(--spacing-2xl);
}

.section-header h2 {
  font-size: var(--text-3xl);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
  color: var(--color-primary);
}

.section-subtitle {
  color: var(--color-primary);
  font-size: var(--text-lg);
  margin: 0;
}

/* ============================================
     POUR QUI ? (AUDIENCE)
     ============================================ */
.target-audience-section {
  padding: var(--spacing-2xl) 0;
  background: var(--color-surface);
}

.audience-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--spacing-xl);
  margin-top: var(--spacing-xl);
}

.audience-card {
  border-top: 4px solid #f7ab3f !important;
  background: var(--color-background);
  padding: var(--spacing-xl);
  border-radius: var(--radius-lg);
  text-align: center;
  border: 1px solid var(--color-border);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.audience-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--color-secondary);
}

.audience-icon {
  width: 80px;
  height: 80px;
  background: #333249 !important;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--spacing-lg);
  transition: transform 0.3s ease;
}

.audience-icon i {
  font-size: var(--text-2xl);
  color: white;
}

.audience-card h3 {
  font-size: var(--text-xl);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: var(--color-primary);
}

.audience-card p {
  color: var(--color-primary);
  line-height: 1.6;
  font-size: var(--text-base);
}

/* Bouton Voir Toutes les Formations */
.see-all-formations {
  text-align: center;
  margin-top: var(--spacing-2xl);
  display: flex;
  justify-content: center;
}

/* Responsive - Bouton Voir Toutes */
@media (max-width: 768px) {
  .see-all-formations {
    margin-top: var(--spacing-xl);
  }
}

/* ============================================
     SELECTED PROFILE
     ============================================ */
.selected-profile-header {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.back-button {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-sm);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--color-primary);
  font-size: var(--text-sm);
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-bottom: var(--spacing-lg);
}

.back-button:hover {
  background: var(--color-border);
  transform: translateX(-2px);
}

.back-button i {
  font-size: var(--text-sm);
}

.selected-profile-header h3,
.selected-category-header h3 {
  font-size: var(--text-2xl);
  font-weight: 600;
  color: var(--color-primary);
  margin: 0;
}

.formation-count {
  background: #3332490f;
  width: max-content;
  padding: 1em;
  border-radius: 64px;
  color: #00000052;
  margin: 2em 0;
}

/* ============================================
     CHIFFRES CLÉS
     ============================================ */
.key-figures-section {
  padding: var(--spacing-2xl) 0;
  background: var(--color-background);
}

.figures-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: var(--spacing-xl);
  margin-top: var(--spacing-xl);
}

.figure-card {
  text-align: center;
  padding: var(--spacing-xl);
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  transition: all 0.3s ease;
}

.figure-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.figure-number {
  font-size: 3.5rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-bottom: var(--spacing-sm);
  position: relative;
  display: inline-block;
}

.figure-plus,
.figure-percent {
  position: absolute;
  font-weight: 600;
  color: var(--color-accent);
}

.figure-plus {
  font-size: 2rem;
  top: 0;
  right: -25px;
}

.figure-percent {
  font-size: 1.8rem;
  bottom: 5px;
  right: -20px;
}

.figure-label {
  font-size: var(--text-lg);
  color: var(--color-secondary);
  font-weight: 500;
}

/* ============================================
     LE FORMATEUR
     ============================================ */
.trainer-section {
  padding: var(--spacing-2xl) 0;
  background: var(--color-surface);
}

.trainer-content {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: var(--spacing-2xl);
  align-items: center;
}

.trainer-image {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
}

.trainer-image img {
  width: 100%;
  height: 400px;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.trainer-image:hover img {
  transform: scale(1.05);
}

.trainer-info h2 {
  font-size: var(--text-3xl);
  font-weight: 600;
  margin-bottom: var(--spacing-lg);
  color: var(--color-primary);
}

.trainer-info p {
  font-size: var(--text-lg);
  line-height: 1.7;
  color: var(--color-primary);
  margin-bottom: var(--spacing-xl);
}

.trainer-credentials {
  display: flex;
  gap: var(--spacing-lg);
  flex-wrap: wrap;
}

.credential-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  background: var(--color-background);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}

.credential-item i {
  color: var(--color-accent);
  font-size: var(--text-lg);
}

.credential-item span {
  font-weight: 500;
  color: var(--color-primary);
}

/* ============================================
     FAQ
     ============================================ */
.faq-section {
  padding: var(--spacing-2xl) 0;
  background: var(--color-background);
}

.faq-container {
  max-width: 800px;
  margin: var(--spacing-xl) auto 0;
}

.faq-item {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  border: 1px solid var(--color-border);
  overflow: hidden;
  transition: all 0.3s ease;
}

.faq-item:hover {
  box-shadow: var(--shadow-md);
}

.faq-question {
  padding: var(--spacing-lg);
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background-color 0.3s ease;
}

.faq-question:hover {
  background: rgba(0, 102, 255, 0.05);
}

.faq-question h3 {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-primary);
  margin: 0;
  flex: 1;
}

.faq-icon {
  transition: transform 0.3s ease;
  color: var(--color-accent);
}

.faq-icon.active {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition:
    max-height 0.3s ease,
    padding 0.3s ease;
  background: var(--color-background);
}

.faq-answer.active {
  max-height: 200px;
  padding: var(--spacing-lg);
}

.faq-answer p {
  color: var(--color-secondary);
  line-height: 1.6;
  margin: 0;
}

/* ============================================
     FORMATIONS GRID
     ============================================ */
.formations-grid-section {
  padding: var(--spacing-2xl) 0;
  background: var(--color-background);
}

.formations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: var(--spacing-xl);
  align-items: stretch;
}

.formation-card {
  background: var(--color-background);
  border: solid 1px #333249ad;
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-shadow: var(--shadow-sm);
  animation: fadeIn 0.6s ease-out;
}

.formation-card:hover {
  border-color: var(--color-secondary);
  transform: translateY(-4px);
}

.formation-card:nth-child(1) {
  animation-delay: 0.1s;
}
.formation-card:nth-child(2) {
  animation-delay: 0.2s;
}
.formation-card:nth-child(3) {
  animation-delay: 0.3s;
}
.formation-card:nth-child(4) {
  animation-delay: 0.4s;
}
.formation-card:nth-child(5) {
  animation-delay: 0.5s;
}
.formation-card:nth-child(6) {
