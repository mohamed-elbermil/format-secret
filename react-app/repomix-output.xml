  background: var(--color-primary);
  padding: var(--padding-hero-desktop);
  position: relative;
  overflow: hidden;
  z-index: 0;
}

.about-hero::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -20px;
  width: 220px;
  height: 220px;
  background-image: radial-gradient(#ffffff 1.5px, transparent 1.5px);
  background-size: 12px 12px;
  opacity: 0.25;
}

.about-hero-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  z-index: 2;
}

.about-hero-text {
  color: var(--text-on-primary);
}

.about-hero h1 {
  font-size: var(--font-size-hero-title);
  line-height: 1.1;
  font-weight: var(--font-weight-hero-title);
  color: var(--text-on-primary);
  margin-bottom: 24px;
}

.about-hero p {
  font-size: var(--font-size-hero-subtitle);
  opacity: 0.95;
  margin-bottom: 32px;
  color: var(--text-on-primary-light);
  line-height: 1.6;
}

.about-hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.about-hero-image {
  position: relative;
  width: 100%;
  max-width: 400px;
}

.about-hero-image img {
  width: 100%;
  height: auto;
  border-radius: 280px 0 0 0;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  transition: transform 0.3s ease;
}

.about-hero-badge {
  position: absolute;
  top: -20px;
  right: -20px;
  width: 120px;
  height: 120px;
  background: var(--color-secondary);
