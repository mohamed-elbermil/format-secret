    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }
  .figure-number {
    font-size: 2.5rem;
  }
  .figure-plus,
  .figure-percent {
    font-size: 1.5rem;
  }

  .trainer-content {
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    text-align: center;
  }
  .trainer-image img {
    height: 300px;
  }
  .trainer-credentials {
    justify-content: center;
  }

  .faq-container {
    margin: var(--spacing-lg) auto 0;
  }
  .faq-question {
    padding: var(--spacing-md);
  }
  .faq-question h3 {
    font-size: var(--text-base);
  }
  .faq-answer.active {
    max-height: 300px;
  }

  .formations-grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }
  .contact-grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }
  .card-image-container {
    height: 180px;
  }
  .card-content {
    padding: var(--spacing-md) var(--spacing-md) 0;
  }
  .card-title {
    font-size: var(--text-lg);
  }
  .card-badge {
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    font-size: 10px;
  }
  .card-stats {
    padding: var(--spacing-sm);
  }

  .reassurance-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }
  .reassurance-item {
    padding: var(--spacing-md);
  }
  .reassurance-icon {
    width: 60px;
    height: 60px;
  }
  .reassurance-icon i {
    font-size: var(--text-xl);
  }
  .reassurance-item h3 {
    font-size: var(--text-base);
  }
  .reassurance-item p {
    font-size: var(--text-xs);
  }

  .seo-columns {
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }
  .seo-content h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--spacing-xl);
  }
  .seo-column h3 {
    font-size: var(--text-lg);
  }
  .seo-column p {
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .modal-overlay {
    padding: var(--spacing-md);
  }
  .modal-content {
    max-height: 95vh;
  }
  .modal-header {
    padding: var(--spacing-lg) var(--spacing-lg) 0;
  }
  .modal-header h2 {
    font-size: var(--text-xl);
  }
  .modal-body {
    padding: var(--spacing-lg);
  }
  .modal-info-grid {
