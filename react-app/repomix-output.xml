}

.badge-content {
  text-align: center;
  color: var(--color-primary);
}

.badge-content i {
  font-size: 1.5rem;
  margin-bottom: 4px;
  display: block;
}

.badge-content span {
  font-weight: 700;
  font-size: 0.85rem;
  line-height: 1;
}

@keyframes float {
