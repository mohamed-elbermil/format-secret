}

.social-media a:hover {
  color: #fbbf24;
}

.contact-form {
  background-color: #f9fafb;
  padding: 32px 38px;
}

.contact-form h3 {
  font-size: 1.6rem;
  color: #111827;
  margin: 0 0 24px;
}

