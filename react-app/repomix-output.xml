  display: flex;
  flex-direction: column;
  gap: 18px;
}

.form-row {
  display: flex;
  gap: 20px;
}

.form-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  text-align: left;
  display: block;
  font-size: 0.9rem;
  color: #6b7280;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 8px 0;
  border: 0;
  border-bottom: 2px solid #e5e7eb;
  border-radius: 0;
  font-size: 0.98rem;
  background: transparent;
}

.form-group textarea {
  height: 120px;
  resize: vertical;
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-bottom-color: var(--color-secondary);
}

.btn-secondary {
  background: var(--color-secondary);
}

.btn {
  text-decoration: none;
  padding: 12px 17px;
  color: black;
  border-radius: 44px;
  border: none;
}

.btn-primary {
  background-color: var(--color-primary);
  color: #fff;
}

.btn-primary a {
  text-decoration: none;
}

.btn-dark {
  background: var(--color-primary);
  padding: 1em 2em;
  border-radius: 64px;
  color: #fff;
  text-decoration: none;
}

.submit-btn {
  background-color: var(--color-secondary);
  color: #111827;
  border: none;
  padding: 12px 30px;
  font-size: 1rem;
  border-radius: 999px;
  cursor: pointer;
  transition:
    background-color 0.2s ease,
    transform 0.1s ease,
    box-shadow 0.2s ease;
}

.submit-btn:hover {
  background-color: #fbbf24;
  box-shadow: 0 10px 25px rgba(15, 23, 42, 0.12);
  transform: translateY(-1px);
}

.contact-form-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16px;
  margin-top: 8px;
}

/* Loading Spinner */
.loading-spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid #ffffff;
  border-radius: 50%;
  border-top-color: transparent;
  animation: spin 1s ease-in-out infinite;
  margin-right: 8px;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* Enhanced Form Messages */
.form-success,
.form-error {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  border-radius: 8px;
  margin-top: 16px;
  font-size: 14px;
  font-weight: 500;
  animation: slideIn 0.3s ease-out;
}

.form-success {
  background-color: #10b981;
  color: white;
  border: 1px solid #059669;
}

.form-error {
  background-color: #ef4444;
  color: white;
  border: 1px solid #dc2626;
}

.form-success i,
.form-error i {
  font-size: 16px;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media screen and (max-width: 768px) {
  .contact-content {
    flex-direction: column;
    border-radius: 22px;
  }

  .contact-info {
    max-width: none;
    border-radius: 22px 22px 0 0;
  }

  .social-media {
    justify-content: flex-start;
  }
}

