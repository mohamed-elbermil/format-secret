  background: #3332491f;
  color: #fff;
  margin-top: auto;
}

.stat-item {
  text-align: center;
  flex: 1;
  padding: 15px 0;
}

.stat-item:first-child {
  border-right: 2px solid #333249;
}

.stat-value {
