/* Présentation */

.services {
  padding: 80px 0;
  background-color: #ffffff;
}

.services h2,
.presentation h3 {
  text-align: center;
  font-size: 2.5rem;
  color: var(--color-primary);
  margin-bottom: 50px;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
}

.service-card {
  background-color: #ffffff;
  border-radius: 15px;
  overflow: hidden;
  transition: all 0.3s ease;
  border: solid 1px var(--color-primary);
}

.service-image {
  height: 200px;
  overflow: hidden;
}

.service-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.service-card:hover .service-image img {
  transform: scale(1.1);
}

.service-card h3 {
  font-size: 1.5rem;
  margin: 20px 20px 10px;
  color: var(--color-primary);
  text-align: center;
}

.title-style {
  font-weight: 400;
}

.service-card p {
  font-size: 1rem;
  color: #666666;
  line-height: 1.6;
  margin: 0 20px 20px;
}

.presentation iframe {
  width: 100%;
  height: 69vh;
  border-radius: 29px;
  /* box-shadow: 22px 20px 60px #0000005e; */
}

.orientation {
  padding: 80px 0;
  background: #fff;
}
.orientation h2 {
  text-align: center;
  font-size: 2.4rem;
  color: var(--color-primary);
  margin-bottom: 6px;
}
.orientation-subtitle {
  text-align: center;
  color: #666;
  margin-bottom: 30px;
}
.orientation-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 22px;
}
.orientation-images img {
  border: solid 2px var(--color-primary);
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  border-radius: 34px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}
.orientation-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin: 10px 0 24px;
}
.orientation-step {
  text-align: left;
  color: var(--color-primary);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 1em 2em;
  border-radius: 11px;
  background: var(--color-primary) 14;
}
.orientation-step-title {
  font-weight: 600;
  margin-bottom: 6px;
}
.orientation-step-time {
  color: #666;
  font-size: 0.95rem;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.orientation-cta {
  display: flex;
  justify-content: center;
  margin-top: 10px;
}

/* FAQ globale */
.global-faq {
  padding: 14em 0;
  background: #ffffff;
}

.global-faq h2 {
  text-align: center;
  font-size: 2.2rem;
  margin: 0 0 34px;
  color: #111827;
}

.global-faq-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px 24px;
}

.global-faq-item {
  text-align: left;
  padding: 14px 18px;
  border-radius: 6px;
  border: 1px solid #e5e7eb;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 10px;
  cursor: pointer;
  transition:
    background 0.2s ease,
    border-color 0.2s ease,
    box-shadow 0.2s ease;
  font: inherit;
  color: #111827;
}

.global-faq-item:hover {
  background: #ffffff;
  border-color: #d1d5db;
  box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
}

.global-faq-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: 100%;
}

.global-faq-question {
  flex: 1;
  font-size: 0.98rem;
  text-align: left;
}

.global-faq-icon {
  flex-shrink: 0;
  font-size: 1.2rem;
  color: #6b7280;
}

.global-faq-answer {
  display: block;
  width: 100%;
  margin-top: 0;
  font-size: 0.9rem;
  color: #4b5563;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition:
    max-height 0.25s ease,
    opacity 0.25s ease,
    margin-top 0.25s ease;
}

.global-faq-answer.is-open {
  max-height: 220px;
  opacity: 1;
  margin-top: 10px;
}

@media screen and (max-width: 900px) {
  .global-faq-grid {
    grid-template-columns: 1fr;
  }
}

@media screen and (max-width: 1024px) {
  .orientation-images,
  .orientation-steps {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media screen and (max-width: 640px) {
  .orientation-images,
  .orientation-steps {
    grid-template-columns: 1fr;
  }
}

.map-banner {
  width: 100%;
  background: #f9f9f9;
}
.map-banner iframe {
  display: block;
  width: 100%;
  height: 420px;
  border: 0;
}

@media screen and (max-width: 768px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
}

