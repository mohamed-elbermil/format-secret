/* MODAL FORMATION */
/* Modal styles */
.modal {
  display: none;
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(
    -50%,
    -50%
  ); /* Décale l'élément de la moitié de sa propre largeur/hauteur */

  background-color: #ffffffd1;
  padding: 25px;
  border: none;
  width: 90%;
  max-width: 800px;
  border-radius: 40px;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
  max-height: 90vh;
  overflow-y: auto;
  backdrop-filter: blur(5px);
}

.modal-flex-content {
  display: flex;
  flex-wrap: wrap;
  gap: 25px;
  margin-top: 15px;
}

.modal-description {
  flex: 1;
  min-width: 280px;
  padding: 2em;
  background: #ffffff;
  border-radius: 26px;
}

.modal-calendar {
  flex: 1;
  min-width: 280px;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  margin-top: 15px;
  background-color: #f9f9f9;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  height: min-content;
}

.modal-calendar::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background-color: var(--color-secondary);
  z-index: 10;
}

.modal-calendar iframe {
  display: block;
  width: 100%;
  height: 380px;
  border: none;
  background-color: transparent;
  position: relative;
  z-index: 5;
